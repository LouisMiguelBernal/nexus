# ==========================================================================
# Nexus - Environment template
# --------------------------------------------------------------------------
# Copy this file to `backend/.env` and fill in the keys you want to use.
#
#   cp .env.example backend/.env
#
# EVERY KEY IS OPTIONAL. Live market data (order books, trades, funding, OI)
# streams from the PUBLIC Binance / OKX / MEXC WebSocket + REST endpoints and
# needs no credentials. Keys below only enable extra, opt-in features and the
# app degrades gracefully without them.
#
# NEVER commit your filled-in .env - it is gitignored. Use READ-ONLY API keys.
# ==========================================================================

# --- Binance (READ-ONLY, USDⓈ-M Futures) ---------------------------------
# Only needed for the Trading Journal (your own account fills / balances).
# Create a read-only key with NO withdrawal/trade permissions.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- OKX (READ-ONLY market data) -----------------------------------------
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# --- MEXC (READ-ONLY market data) ----------------------------------------
MEXC_API_KEY=
MEXC_SECRET_KEY=
MEXC_IP=

# --- News & macro (free tiers) -------------------------------------------
# Finnhub: crypto news headlines.       https://finnhub.io  (free tier)
FINNHUB_API_KEY=
# CoinMarketCap: reference prices.      https://coinmarketcap.com/api (free)
CMC_API_KEY=
# FRED: macro series (CPI, rates...).   https://fred.stlouisfed.org (free)
FRED_API_KEY=
# Etherscan: on-chain (optional).       https://etherscan.io/apis (free)
ETHERSCAN_API_KEY=

# --- Telegram alerts (optional) ------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
